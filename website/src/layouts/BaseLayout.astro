---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Semantic Signal LLM | Engineering Landing Page",
  description = "Memory-augmented, paper-trading focused LLM trading framework with FastAPI telemetry and vector-memory reflection loops."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-shell-950 text-slate-200 antialiased">
    <div class="ambient-grid"></div>
    <main class="relative z-10 mx-auto w-full max-w-7xl px-4 py-10 md:px-8 md:py-14">
      <slot />
    </main>
  </body>
</html>