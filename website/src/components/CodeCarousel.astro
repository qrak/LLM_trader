---
import { snippets } from "../data/site";
---

<div class="panel p-4">
  <div class="mb-3 flex items-center justify-between">
    <p class="section-title">Implementation Snippets</p>
    <span class="mono text-xs text-slate-400">typed python excerpts</span>
  </div>
  <div class="mb-3 flex flex-wrap gap-2">
    <button class="code-tab rounded border border-slate-600 bg-slate-800 px-3 py-1.5 text-xs font-semibold text-slate-200" data-target="snippet-analyzer">analyzer</button>
    <button class="code-tab rounded border border-slate-600 bg-slate-800 px-3 py-1.5 text-xs font-semibold text-slate-200" data-target="snippet-platforms">platforms</button>
    <button class="code-tab rounded border border-slate-600 bg-slate-800 px-3 py-1.5 text-xs font-semibold text-slate-200" data-target="snippet-trading">trading</button>
  </div>

  <pre id="snippet-analyzer" class="snippet mono overflow-x-auto rounded-lg border border-slate-700 bg-slate-950 p-3 text-[12px] leading-relaxed text-cyan-100"><code>{snippets.analyzer}</code></pre>
  <pre id="snippet-platforms" class="snippet mono hidden overflow-x-auto rounded-lg border border-slate-700 bg-slate-950 p-3 text-[12px] leading-relaxed text-cyan-100"><code>{snippets.platforms}</code></pre>
  <pre id="snippet-trading" class="snippet mono hidden overflow-x-auto rounded-lg border border-slate-700 bg-slate-950 p-3 text-[12px] leading-relaxed text-cyan-100"><code>{snippets.trading}</code></pre>
</div>

<script>
  const tabs = Array.from(document.querySelectorAll(".code-tab"));
  const snippets = Array.from(document.querySelectorAll(".snippet"));

  const activate = (targetId) => {
    snippets.forEach((el) => {
      const selected = el.id === targetId;
      el.classList.toggle("hidden", !selected);
    });
    tabs.forEach((btn) => {
      const selected = btn.getAttribute("data-target") === targetId;
      btn.classList.toggle("border-cyan-300", selected);
      btn.classList.toggle("text-cyan-100", selected);
      btn.classList.toggle("bg-cyan-500/10", selected);
    });
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const targetId = tab.getAttribute("data-target");
      if (targetId) {
        activate(targetId);
      }
    });
  });

  activate("snippet-analyzer");
</script>