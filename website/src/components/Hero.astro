---
import { site } from "../data/site";
---

<section class="panel mb-6 overflow-hidden p-6 md:p-10">
  <div class="grid items-start gap-8 lg:grid-cols-[1.4fr_1fr]">
    <div>
      <p class="section-title">Semantic Signal LLM</p>
      <h1 class="mt-3 max-w-3xl text-3xl font-semibold leading-tight text-slate-100 md:text-5xl">
        {site.headline}
      </h1>
      <p class="mt-5 max-w-3xl text-base leading-relaxed text-slate-300 md:text-lg">
        {site.subheadline}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={site.dashboardUrl}
          class="inline-flex items-center gap-2 rounded-lg border border-cyan-300/40 bg-cyan-400/10 px-5 py-3 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-300/20"
          target="_blank"
          rel="noreferrer"
        >
          <span class="h-2.5 w-2.5 rounded-full bg-cyan-300 animate-telemetry"></span>
          Launch Live Demo Dashboard
        </a>
        <a
          href={site.repoUrl}
          class="inline-flex items-center rounded-lg border border-slate-600 bg-slate-800/50 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-slate-500 hover:bg-slate-700/60"
          target="_blank"
          rel="noreferrer"
        >
          Explore the Code
        </a>
      </div>
    </div>
    <div class="rounded-xl2 border border-slate-700 bg-shell-800/70 p-4 shadow-ring">
      <p class="mono text-xs uppercase tracking-[0.18em] text-cyan-200/80">Runtime Snapshot</p>
      <div class="mt-4 space-y-3 text-sm text-slate-300">
        <div class="flex items-center justify-between rounded-md border border-slate-700 bg-slate-900/70 px-3 py-2">
          <span>Event Loop</span>
          <span class="mono text-cyan-200">asyncio active</span>
        </div>
        <div class="flex items-center justify-between rounded-md border border-slate-700 bg-slate-900/70 px-3 py-2">
          <span>Vector Memory</span>
          <span class="mono text-mint">ChromaDB online</span>
        </div>
        <div class="flex items-center justify-between rounded-md border border-slate-700 bg-slate-900/70 px-3 py-2">
          <span>Risk Guards</span>
          <span class="mono text-amber-200">hard + soft exits</span>
        </div>
      </div>
    </div>
  </div>
</section>