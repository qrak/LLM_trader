[ai_providers]
provider = googleai

lm_studio_base_url = http://localhost:1234/v1
lm_studio_model =
lm_studio_streaming = false

openrouter_base_url = https://openrouter.ai/api/v1
openrouter_base_model = google/gemini-3-flash-preview
openrouter_fallback_model = deepseek/deepseek-r1:free

google_studio_model = gemini-3.5-flash

[general]
crypto_pair = BTC/USDC
timeframe = 4h
candle_limit = 999
ai_chart_candle_limit = 125
discord_bot = false

include_coin_description = false

[debug]
save_chart_images = false
chart_save_path = chart_images
logger_debug = true

[directories]
log_dir = logs
data_dir = data

[rag]
update_interval_hours = 4
categories_update_interval_hours = 168
coingecko_update_interval_hours = 24
defillama_update_interval_hours = 0.25
coingecko_global_api_url = https://api.coingecko.com/api/v3/global
news_limit = 5
article_max_tokens = 1000
news_sources =
news_source_coindesk_url = https://www.coindesk.com/arc/outboundfeeds/rss/
news_source_cointelegraph_url = https://cointelegraph.com/rss
news_source_decrypt_url = https://decrypt.co/feed
news_source_cryptoslate_url = https://cryptoslate.com/feed/
news_page_enrichment = true
news_min_body_chars = 400
news_timeout_seconds = 20
rag_update_timeout_seconds = 180
news_fetch_total_timeout_seconds = 45
news_enrichment_timeout_seconds = 120
news_max_concurrency = 6
news_max_items_per_source = 100
density_penalty_threshold = 300
density_boost_threshold = 1000
density_penalty_multiplier = 0.5
density_boost_multiplier = 1.2
cooccurrence_multiplier = 1.5
news_crawl4ai_enabled = true
news_crawl_timeout = 120

[exchanges]
supported = binance,kucoin,gateio,mexc,hyperliquid
market_refresh_hours = 24

[demo_trading]
demo_quote_capital = 10000
transaction_fee_percent = 0.00075

[risk_management]
stop_loss_type = hard
take_profit_type = hard
stop_loss_check_interval = 15m
take_profit_check_interval = 15m
max_position_size = 0.10
position_size_fallback_low = 0.01
position_size_fallback_medium = 0.02
position_size_fallback_high = 0.03

sl_tightening_scalping = 0.25
sl_tightening_intraday = 0.20
sl_tightening_swing = 0.15
sl_tightening_position = 0.10
sl_tightening_floor = 0.05
sl_tightening_ceiling = 0.40
sl_tightening_min_samples = 10

[cooldowns]
file_message_expiry = 168

[model_config]
temperature = 0.7
top_p = 0.9
top_k = 40
max_tokens = 32768

google_max_tokens = 32768
google_thinking_level = high
google_code_execution = false
model_verbosity = high

[dashboard]
enabled = true
host = 0.0.0.0
port = 8000
enable_cors = false
cors_origins = *
